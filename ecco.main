-- // NOTIFICATION SYSTEM
local notificationGui = Instance.new("ScreenGui")
notificationGui.Name = "VanityNotifications"
notificationGui.ResetOnSpawn = false
notificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
notificationGui.IgnoreGuiInset = true
pcall(function() notificationGui.Parent = game:GetService("CoreGui") end)
if not notificationGui.Parent then notificationGui.Parent = LocalPlayer:WaitForChild("PlayerGui") end

local function showNotification(message)
    local frame = Instance.new("Frame")
    frame.Name = "NotificationFrame"
    frame.Size = UDim2.new(0, 400, 0, 0)
    frame.Position = UDim2.new(0.5, 0, 0, -100)
    frame.AnchorPoint = Vector2.new(0.5, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    frame.BackgroundTransparency = 0.3
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    frame.Parent = notificationGui
    
    -- Add rounded corners
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = frame
    
    -- Add gradient
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(30, 30, 40)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 15, 20))
    }
    gradient.Rotation = 90
    gradient.Parent = frame
    
    -- Title
    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.Size = UDim2.new(1, -20, 0, 30)
    title.Position = UDim2.new(0, 10, 0, 10)
    title.BackgroundTransparency = 1
    title.Text = "📢 VANITY NOTIFICATION"
    title.TextColor3 = Color3.fromRGB(255, 50, 50)
    title.TextSize = 16
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = frame
    
    -- Message
    local msgLabel = Instance.new("TextLabel")
    msgLabel.Name = "Message"
    msgLabel.Size = UDim2.new(1, -20, 0, 60)
    msgLabel.Position = UDim2.new(0, 10, 0, 45)
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    msgLabel.TextSize = 14
    msgLabel.Font = Enum.Font.Gotham
    msgLabel.TextWrapped = true
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.TextYAlignment = Enum.TextYAlignment.Top
    msgLabel.Parent = frame
    
    -- Progress bar
    local progressBg = Instance.new("Frame")
    progressBg.Name = "ProgressBg"
    progressBg.Size = UDim2.new(1, 0, 0, 3)
    progressBg.Position = UDim2.new(0, 0, 1, -3)
    progressBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    progressBg.BorderSizePixel = 0
    progressBg.Parent = frame
    
    local progressBar = Instance.new("Frame")
    progressBar.Name = "Progress"
    progressBar.Size = UDim2.new(1, 0, 1, 0)
    progressBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    progressBar.BorderSizePixel = 0
    progressBar.Parent = progressBg
    
    -- Animate in
    frame:TweenSize(
        UDim2.new(0, 400, 0, 120),
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Back,
        0.5,
        true
    )
    
    frame:TweenPosition(
        UDim2.new(0.5, 0, 0, 20),
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Back,
        0.5,
        true
    )
    
    -- Progress bar animation
    task.spawn(function()
        task.wait(0.5)
        progressBar:TweenSize(
            UDim2.new(0, 0, 1, 0),
            Enum.EasingDirection.InOut,
            Enum.EasingStyle.Linear,
            5,
            true
        )
    end)
    
    -- Auto dismiss after 5 seconds
    task.wait(5.5)
    
    -- Animate out
    frame:TweenPosition(
        UDim2.new(0.5, 0, 0, -150),
        Enum.EasingDirection.In,
        Enum.EasingStyle.Back,
        0.3,
        true
    )
    
    task.wait(0.3)
    frame:Destroy()
end

-- Check for notifications periodically
task.spawn(function()
    while true do
        task.wait(3) -- Check every 3 seconds
        
        local key = CFG['General']['Key'] or ""
        if key == "YOUR_KEY_HERE" or key == "" then
            task.wait(10)
            continue
        end
        
        local apiUrl = "https://worker-production-31dc.up.railway.app"
        local request_func = (http_request or request or (syn and syn.request))
        
        local success, response
        if request_func then
            success, response = pcall(function()
                return request_func({
                    Url = apiUrl .. "/notifications?key=" .. key,
                    Method = "GET"
                })
            end)
            
            if success and response.StatusCode == 200 then
                local ok, data = pcall(function()
                    return HttpService:JSONDecode(response.Body)
                end)
                
                if ok and data.notifications then
                    for _, notif in ipairs(data.notifications) do
                        showNotification(notif.message)
                        task.wait(0.5) -- Delay between multiple notifications
                    end
                end
            end
        else
            success, response = pcall(function()
                return game:HttpGet(apiUrl .. "/notifications?key=" .. key)
            end)
            
            if success then
                local ok, data = pcall(function()
                    return HttpService:JSONDecode(response)
                end)
                
                if ok and data.notifications then
                    for _, notif in ipairs(data.notifications) do
                        showNotification(notif.message)
                        task.wait(0.5)
                    end
                end
            end
        end
    end
end)

