-- // POTASSIUM FREEZE FIX
-- Prevents game freezing on respawn/death for Potassium executor
local function isPotassiumExecutor()
    local executorName = (identifyexecutor and identifyexecutor()) or (getexecutorname and getexecutorname()) or ""
    return executorName:lower():find("potassium") ~= nil
end

if isPotassiumExecutor() then
    print("[Vanity] Potassium executor detected - Applying freeze fix")
    
    -- Monitor character respawns and prevent freezing
    LocalPlayer.CharacterAdded:Connect(function(character)
        print("[Vanity] Character respawned - Freeze protection active")
        -- Ensure no freeze occurs on respawn
        task.spawn(function()
            task.wait(0.1)
            -- Force immediate unfreezing if needed
            if character and character:FindFirstChild("HumanoidRootPart") then
                character.HumanoidRootPart.Anchored = false
            end
        end)
    end)
    
    -- Monitor health changes to prevent death-related freezing
    local function setupDeathProtection(character)
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.Died:Connect(function()
                print("[Vanity] Death detected - Freeze protection active")
                -- Prevent any freeze on death by keeping game responsive
                task.spawn(function()
                    task.wait(0.1)
                    -- Game remains responsive
                end)
            end)
        end
    end
    
    if LocalPlayer.Character then
        setupDeathProtection(LocalPlayer.Character)
    end
    
    LocalPlayer.CharacterAdded:Connect(setupDeathProtection)
end

